# Flutter/Dart ignores (standard and safe)
.dart_tool/
.packages
.flutter-plugins
.flutter-plugins-dependencies
.pub-cache/
.pub/
build/
coverage/
**/doc/api/
**/ios/Flutter/.last_build_id
**/ios/Runner/GeneratedPluginRegistrant.*

# Android specific
**/android/**/gradle-wrapper.jar
**/android/gradle/
**/android/local.properties
**/android/**/GeneratedPluginRegistrant.java
**/android/key.properties
*.jks

# iOS / Xcode specific
**/ios/**/*.mode1v3
**/ios/**/*.mode2v3
**/ios/**/*.moved-aside
**/ios/**/*.pbxuser
**/ios/**/*.perspectivev3
**/ios/**/.sconsign.dblite
**/ios/**/.symlinks/
**/ios/**/DerivedData/
**/ios/**/Pods/
**/ios/**/xcuserdata/
**/ios/Flutter/ephemeral/
**/ios/Flutter/flutter_export_environment.sh
**/ios/Runner/GeneratedPluginRegistrant.*

# macOS
**/macos/Flutter/ephemeral/
**/macos/Flutter/GeneratedPluginRegistrant.swift

# Windows
**/windows/flutter/generated_plugin_registrant.*
**/windows/flutter/generated_plugins.cmake

# Linux
**/linux/flutter/generated_plugin_registrant.*
**/linux/flutter/generated_plugins.cmake

# Web
**/web/build/
**/web/icons/
**/web/manifest.json

# General ignores
*.log
*.swp
*.swo
*.bak
*.tmp
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# Optional: ignore pubspec.lock if you don't want lockfile changes in git
# (most teams commit it, so keep it unless you have a good reason)
# pubspec.lock

# Exceptions (keep these!)
!**/ios/**/default.mode1v3
!**/ios/**/default.mode2v3
!**/ios/**/default.pbxuser
!**/ios/**/default.perspectivev3